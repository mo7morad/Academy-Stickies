{
  "name": "academy-stickies",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Private, invite-only academy sticky-notes app on Cloudflare Pages (D1 + R2 + Email Sending).",
  "scripts": {
    "dev": "npm run build && concurrently -k -n vite,cf -c green,cyan \"vite build --watch\" \"wrangler pages dev --live-reload\"",
    "build": "vite build",
    "serve": "npm run build && wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "db:local": "wrangler d1 execute stickies-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute stickies-db --remote --file=./schema.sql",
    "migrate:local": "wrangler d1 execute stickies-db --local --file=./migrations/0001_anon_pseudonym.sql",
    "migrate:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0001_anon_pseudonym.sql",
    "migrate2:local": "wrangler d1 execute stickies-db --local --file=./migrations/0002_cohort_profiles.sql",
    "migrate2:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0002_cohort_profiles.sql",
    "migrate3:local": "wrangler d1 execute stickies-db --local --file=./migrations/0003_cohort_thumbs.sql",
    "migrate3:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0003_cohort_thumbs.sql",
    "migrate4:local": "wrangler d1 execute stickies-db --local --file=./migrations/0004_mentor_stickies.sql",
    "migrate4:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0004_mentor_stickies.sql",
    "migrate5:local": "wrangler d1 execute stickies-db --local --file=./migrations/0005_feedback.sql",
    "migrate5:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0005_feedback.sql",
    "migrate6:local": "wrangler d1 execute stickies-db --local --file=./migrations/0006_mentor_wall_public.sql",
    "migrate6:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0006_mentor_wall_public.sql",
    "migrate7:local": "wrangler d1 execute stickies-db --local --file=./migrations/0007_profile_edits.sql",
    "migrate7:remote": "wrangler d1 execute stickies-db --remote --file=./migrations/0007_profile_edits.sql",
    "seed": "tsx scripts/seed.ts",
    "seed:remote": "tsx scripts/seed.ts --remote",
    "cohort": "tsx scripts/build-cohort.ts",
    "cohort:remote": "tsx scripts/build-cohort.ts --remote",
    "cohort:media": "tsx scripts/upload-cohort-media.ts",
    "cohort:media:remote": "tsx scripts/upload-cohort-media.ts --remote",
    "links": "tsx scripts/links.ts",
    "links:remote": "tsx scripts/links.ts --remote",
    "invite": "tsx scripts/invite.ts",
    "invite:remote": "tsx scripts/invite.ts --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.functions.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "preact": "^10.25.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@preact/preset-vite": "^2.9.3",
    "concurrently": "^9.1.2",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "wrangler": "^4.20.0"
  }
}
