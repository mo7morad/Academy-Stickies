# Copy to `.dev.vars` for local development (loaded automatically by `wrangler pages dev`).
# NEVER commit `.dev.vars` — it holds secrets.

# Signs the session cookie. Use a long random string, e.g. `openssl rand -base64 48`.
SESSION_SECRET="replace-with-a-long-random-string"

# Public origin used to build magic links + the post-login redirect.
SITE_URL="http://localhost:8788"

# --- Cloudflare Email Sending (optional locally) -------------------------
# Leave blank to skip email; the seed/links scripts still print each magic link.
CF_ACCOUNT_ID=""
CF_EMAIL_API_TOKEN=""
EMAIL_FROM="stickies@yourdomain.com"
EMAIL_FROM_NAME="Academy Stickies"
