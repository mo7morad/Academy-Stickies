# Copy to `.dev.vars` for local development (loaded automatically by `wrangler pages dev`).
# NEVER commit `.dev.vars` — it holds secrets.

# Signs the session cookie. Use a long random string, e.g. `openssl rand -base64 48`.
SESSION_SECRET="replace-with-a-long-random-string"

# Public origin used to build magic links + the post-login redirect.
SITE_URL="http://localhost:8788"

# --- Email via Brevo (optional locally) ----------------------------------
# Leave blank to skip email; the seed/links scripts still print each magic link.
# BREVO_API_KEY: Brevo dashboard → SMTP & API → API Keys (starts with "xkeysib-").
# EMAIL_FROM:    a sender address you've verified in Brevo (Senders & IPs → Senders).
#                No domain needed — a Gmail you own works after the verify click.
BREVO_API_KEY=""
EMAIL_FROM="you@gmail.com"
EMAIL_FROM_NAME="Academy Stickies"

# Where "Send feedback" notifications go. Already set as a plain var in
# wrangler.toml, so this is only needed if you want a different address locally.
# FEEDBACK_NOTIFY_EMAIL="you@example.com"
